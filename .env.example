# =============================================================================
# OMS AI Native - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local development.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=oms_ai_native
POSTGRES_USER=oms_user
POSTGRES_PASSWORD=oms_password
POSTGRES_POOL_SIZE=20

# Full connection string (constructed from above or override directly)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# Full connection string (constructed from above or override directly)
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=oms_user
RABBITMQ_PASSWORD=rabbitmq_password
RABBITMQ_VHOST=oms

# Full connection string (constructed from above or override directly)
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}

# -----------------------------------------------------------------------------
# Claude API / LLM Gateway
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
LLM_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRY=3600

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
