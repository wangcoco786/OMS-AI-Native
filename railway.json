{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build && cd src/frontend && npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "node dist/backend/server.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
